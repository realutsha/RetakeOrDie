<!DOCTYPE html>
<html>
<head>
  <title>RetakeOrDie 💀</title>
  <style>
    body {
      margin: 0;
      background: #04101e;
      color: white;
      text-align: center;
      font-family: Arial;
      overflow: hidden;
    }

    h1 {
      color: #00e0ff;
      text-shadow: 0 0 10px #00e0ff;
    }

    canvas {
      background: linear-gradient(#0b2a4a, #020817);
      border: 3px solid #00e0ff;
      border-radius: 15px;
      box-shadow: 0 0 25px #00e0ff;
    }

    #popup {
      display: none;
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: #111;
      padding: 25px;
      border-radius: 15px;
      box-shadow: 0 0 25px red;
    }

    button {
      padding: 10px 20px;
      margin: 10px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
    }
  </style>
</head>

<body>

<h1>RetakeOrDie 💀</h1>

<audio id="music" loop>
  <source src="music.mp3" type="audio/mpeg">
</audio>

<canvas id="game" width="400" height="600"></canvas>

<div id="popup">
  <h2>RETAKE 💀</h2>
  <p id="msg"></p>
  <button onclick="location.reload()">Try Again</button>
  <button onclick="window.location.href='https://www.facebook.com/RealUtsha'">Follow</button>
</div>

<script>
let c = document.getElementById("game");
let ctx = c.getContext("2d");
let music = document.getElementById("music");

let bird = {x:80,y:250,v:0};
let pipes = [];
let cgpt = 4;
let score = 0;
let gameOver = false;
let speed = 3;

let roasts = [
"Bro studied 5 min 💀",
"Attendance 0 😂",
"Viva destroyed you 😭",
"Assignment wrong file 🤡",
"CGPT crashed 💻"
];

document.onclick = () => {
  if(!gameOver){
    bird.v = -8;
    music.play();
  }
};

function pipe(){
  let top = Math.random()*300+50;
  pipes.push({x:400,top:top,bot:top+150});
}

function draw(){
  ctx.clearRect(0,0,400,600);

  // donkey
  ctx.font="40px Arial";
  ctx.fillText("🫏",bird.x,bird.y);

  // pipes
  pipes.forEach(p=>{
    ctx.fillStyle="red";
    ctx.fillRect(p.x,0,60,p.top);
    ctx.fillRect(p.x,p.bot,60,600);

    if(bird.x< p.x+60 && bird.x+20>p.x &&
      (bird.y< p.top || bird.y>p.bot)){
        hit();
    }

    p.x-=speed;

    if(p.x==bird.x){
      score++;
      if(score%3==0) speed+=0.3;
    }
  });

  // gravity
  bird.v+=0.5;
  bird.y+=bird.v;

  if(bird.y>600||bird.y<0){
    hit();
  }

  // text
  ctx.fillStyle="white";
  ctx.fillText("Score: "+score,10,20);
  ctx.fillText("CGPT: "+cgpt.toFixed(2),10,40);
}

function hit(){
  cgpt-=0.25;

  let msg = roasts[Math.floor(Math.random()*roasts.length)];
  document.getElementById("msg").innerText = msg;

  if(cgpt<=0){
    gameOver=true;
    document.getElementById("popup").style.display="block";
  }
}

setInterval(()=>{if(!gameOver) pipe();},1500);
setInterval(()=>{if(!gameOver) draw();},30);
</script>

</body>
</html>
